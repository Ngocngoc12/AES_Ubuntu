# AES Encryption Web Server - Environment Configuration Example
# Copy this file to .env and update values

# Server Configuration
PORT=3000
NODE_ENV=development

# File Upload Settings
MAX_FILE_SIZE=104857600
MAX_FILES_PARALLEL=5

# File Retention (milliseconds)
FILE_RETENTION_TIME=3600000

# Security
JWT_SECRET=your-secret-key-here-change-this
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000

# Database (if using)
MONGODB_URI=mongodb://localhost:27017/aes-encryption
DATABASE_ENABLED=false

# Logging
LOG_LEVEL=info
DEBUG=false

# API Keys (for external services)
SENDGRID_API_KEY=
SLACK_WEBHOOK_URL=

# Feature Flags
ENABLE_AUDIT_LOG=false
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=false

# Performance
ENABLE_CACHE=false
REDIS_URL=redis://localhost:6379

# SSL/TLS (for HTTPS)
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=

# Email Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aesencryption.com
